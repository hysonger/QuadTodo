{
  "name": "quad-todo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "desktop:win": "tauri build --target x86_64-pc-windows-msvc",
    "desktop:mac": "tauri build --target x86_64-apple-darwin",
    "desktop:mac-arm": "tauri build --target aarch64-apple-darwin",
    "desktop:linux": "tauri build --target x86_64-unknown-linux-gnu",
    "icons:generate": "tauri icon src-tauri/icons/icon.png",
    "tauri:build:full": "npm run icons:generate && npm run tauri:build",
    "desktop:win:full": "npm run icons:generate && npm run desktop:win",
    "desktop:mac:full": "npm run icons:generate && npm run desktop:mac",
    "desktop:mac-arm:full": "npm run icons:generate && npm run desktop:mac-arm",
    "desktop:linux:full": "npm run icons:generate && npm run desktop:linux"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-fs": "^2.0.0",
    "@vueuse/core": "^12.7.0",
    "lucide-vue-next": "^0.475.0",
    "marked": "^15.0.0",
    "pinia": "^3.0.1",
    "uuid": "^11.0.5",
    "vue": "^3.5.13",
    "vue-codemirror": "^6.1.1",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tauri-apps/cli": "^2.10.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.7.3",
    "vite": "^6.1.0",
    "vue-tsc": "^2.2.2"
  }
}
